---
source: tests/render_snapshots.rs
expression: toml
---
schema_version = 1
tool = "whycant"
op = "traverse"
path = "/srv/data/report.txt"
verdict = "blocked"
certainty = "proven"
culprit = "/srv/data not traversable by alice"
blocking_layer = "traverse"
warnings = []

[identity]
target_uid = 1000
target_user = "alice"
primary_gid = 1000
groups = [1000]
group_names = ["alice"]
running_as = "user"
privilege_note = "running as alice (uid 1000); MAC denial confirmation needs sudo"
target_is_self = false

[[evidence_chain]]
name = "/"
kind = "dir"
mark = "pass"
need = "x"
layer = "traverse"

[[evidence_chain]]
name = "srv"
kind = "dir"
mark = "pass"
need = "x"
layer = "traverse"

[[evidence_chain]]
name = "data"
kind = "dir"
mark = "block"
need = "x"
note = "others lack x; alice is not owner or in group staff"
layer = "traverse"

[evidence_chain.evidence]
source = "ls_ld"
raw = "drwxr-x--- 4 root staff 4096 /srv/data"
path = "/srv/data"

[[evidence_chain]]
name = "report.txt"
kind = "file"
mark = "not_reached"
need = "r"

[[layer_results]]
layer = "traverse"
status = "block"
certainty = "proven"
summary = "traverse denied at /srv/data"

[[layer_results.evidence]]
source = "ls_ld"
raw = "drwxr-x--- 4 root staff 4096 /srv/data"
path = "/srv/data"

[[fixes]]
needs_root = true
description = "grant others traverse on the blocking directory"
risk = "low"
rationale = "others need +x to descend into /srv/data toward report.txt"

[fixes.action]
kind = "run"
argv = [
    "chmod",
    "o+x",
    "/srv/data",
]
