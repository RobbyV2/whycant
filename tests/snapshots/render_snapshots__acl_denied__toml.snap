---
source: tests/render_snapshots.rs
expression: toml
---
schema_version = 1
tool = "whycant"
op = "read"
path = "/srv/share/config.yaml"
verdict = "blocked"
certainty = "proven"
culprit = "ACL mask clips www-data to no access on config.yaml"
blocking_layer = "acl"
warnings = ["check for a default ACL on the parent that could re-clip after edits"]

[identity]
target_uid = 33
target_user = "www-data"
primary_gid = 33
groups = [33]
group_names = ["www-data"]
running_as = "user"
privilege_note = "running as www-data (uid 33); MAC denial confirmation needs sudo"
target_is_self = false

[[evidence_chain]]
name = "/"
kind = "dir"
mark = "pass"
need = "x"
layer = "traverse"

[[evidence_chain]]
name = "srv"
kind = "dir"
mark = "pass"
need = "x"
layer = "traverse"

[[evidence_chain]]
name = "share"
kind = "dir"
mark = "pass"
need = "x"
layer = "traverse"

[[evidence_chain]]
name = "config.yaml"
kind = "file"
mark = "block"
need = "r"
note = "mask::--- clips the named-user entry to no effective access"
layer = "acl"

[evidence_chain.evidence]
source = "getfacl"
raw = "user:www-data:r--  #effective:---"
path = "/srv/share/config.yaml"

[[layer_results]]
layer = "acl"
status = "block"
certainty = "proven"
summary = "ACL denies read: named-user entry masked to none"

[[layer_results.evidence]]
source = "getfacl"
raw = "user:www-data:r--  #effective:---"
path = "/srv/share/config.yaml"

[[layer_results.evidence]]
source = "getfacl"
raw = "mask::---"
path = "/srv/share/config.yaml"

[[fixes]]
argv = [
    "setfacl",
    "-m",
    "m::rx",
    "/srv/share/config.yaml",
]
needs_root = true
description = "extend the ACL mask so the existing named-user entry takes effect"
risk = "low"
rationale = "u:www-data:r-- is already present; only the mask is clipping it"
